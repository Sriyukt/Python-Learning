# Program 1: Input validation (no blank values)

def get_non_empty_input(prompt):
    while True:
        value = input(prompt).strip()
        if value == "":
            print("Value cannot be blank. Please enter again.")
        else:
            return value


# Taking inputs
url = get_non_empty_input("Enter URL: ")
description = get_non_empty_input("Enter Description: ")

# Type validation
valid_types = ["Educational", "Search Engine", "Fun"]

while True:
    url_type = get_non_empty_input("Enter Type (Educational/Search Engine/Fun): ")
    if url_type in valid_types:
        break
    else:
        print("Invalid type! Please select from given options.")

# Display result
print("\nEntered Data:")
print("URL:", url)
print("Description:", description)
print("Type:", url_type)

